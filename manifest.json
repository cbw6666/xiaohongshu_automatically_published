{
  "manifest_version": 3,
  "name": "小红书全自动化发布系统",
  "version": "2.0",
  "description": "自动发布小红书内容",
  "icons": {
   
    "48": "images/icon.png"  
  },
  "action": {
    "default_icon": "images/icon.png"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "permissions": [
    "scripting",
    "tabs",
    "activeTab",
    "fileSystem",
    "background",
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [{
    "resources": ["popup.html"],
    "matches": ["<all_urls>"]
  }],
  "background": {
    "service_worker": "background.js",
    "type": "module",
    "persistent": true
  }
} 