{
  "manifest_version": 3,
  "name": "小红书全自动化发布系统",
  "version": "4.0",
  "description": "自动发布小红书内容",
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "permissions": [
    "scripting",
    "tabs",
    "activeTab",
    "fileSystem",
    "background",
    "storage",
    "sidePanel",
    "alarms",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [{
    "resources": ["popup.html"],
    "matches": ["<all_urls>"]
  }],
  "background": {
    "service_worker": "background.js",
    "type": "module",
    "persistent": true
  }
} 